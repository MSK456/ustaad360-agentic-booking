{
  "expo": {
    "name": "Ustaad360",
    "slug": "ustaad360",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#08111F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ustaad360.app"
    },
    "android": {
      "package": "com.ustaad360.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08111F"
      }
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "fbfd1bf9-e740-4b14-870a-ef1248ddc7b8"
      }
    }
  }
}
